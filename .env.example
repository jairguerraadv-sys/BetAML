# BetAML — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores antes de subir a stack:
#   cp .env.example .env
#
# NUNCA comite o arquivo .env em repositórios de código.
# Para gerar novos segredos:
#   JWT_SECRET:          python -c "import secrets; print(secrets.token_hex(32))"
#   PII_ENCRYPTION_KEY:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=betaml
POSTGRES_PASSWORD=devpass
POSTGRES_DB=betaml_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=devpass

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

# ── Segredos da API (ALTERE EM STAGING/PRODUÇÃO) ─────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PII_ENCRYPTION_KEY=ZGV2LXNlY3JldC1lbmNyeXB0aW9uLWtleS0zMmJ5

# ── Aplicação ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
ACCESS_TOKEN_EXPIRE_MIN=60
JWT_ALGORITHM=HS256

# CORS — em produção, lista separada por vírgulas:
# CORS_ALLOW_ORIGINS=https://app.betaml.io,https://admin.betaml.io
CORS_ALLOW_ORIGINS=http://localhost:3000

# Ingest DLQ — número máximo de retentativas antes de registrar o erro:
DLQ_MAX_RETRIES=3

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123

# ── URLs internas (normalmente não alterar em dev) ────────────────────────────
# Use o usuário não-owner `betaml_app` (criado pelas migrations) para que RLS/FORCE RLS
# seja realmente efetivo no runtime. Em casos especiais, sobrescreva para `betaml`.
DATABASE_URL=postgresql://betaml_app:app_devpass_change_me@postgres:5432/betaml_dev
REDIS_URL=redis://:devpass@redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=redpanda:29092
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=betaml-lakehouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=betaml
ML_MODEL_BUCKET=betaml-models
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_TIMEOUT=30000

# ── Webhooks / Segredos internos ──────────────────────────────────────────────
# ALTERE EM STAGING/PRODUÇÃO — gere com: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_WEBHOOK_SECRET=dev-internal-webhook-secret-change-me
EPSILON_WEBHOOK_SECRET=dev-epsilon-webhook-secret-change-me

# ── Modo de deploy ────────────────────────────────────────────────────────────
# saas (multi-tenant) | onprem (single-tenant pré-seed)
DEPLOYMENT_MODE=saas
# Obrigatório quando DEPLOYMENT_MODE=onprem (UUID do tenant pré-seed)
ONPREM_TENANT_ID=

# ── Seed de dados sintéticos ──────────────────────────────────────────────────
# NÃO HABILITAR em staging/produção — cria dados fictícios no banco.
API_AUTO_SEED=false
ALLOW_SYNTHETIC_SEED=false

# ── Validação externa de identidade ──────────────────────────────────────────
# Em staging/produção defina um provider real — 'mock_identity' é BLOQUEADO
# fora de development/test pelo startup guard e pelo dispatcher.
EXTERNAL_VALIDATION_PROVIDER=mock_identity
EXTERNAL_VALIDATION_PROVIDER_URL=
EXTERNAL_VALIDATION_PROVIDER_TOKEN=
EXTERNAL_VALIDATION_PROVIDER_TIMEOUT_SECONDS=5

# ── Observabilidade ───────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
REDPANDA_ADMIN_URL=http://redpanda:9644
ML_SERVICE_URL=http://ml-service:8001
RULES_ENGINE_METRICS_URL=http://rules-engine:8002/metrics
STREAM_PROCESSOR_METRICS_URL=http://stream-processor:8003/metrics
