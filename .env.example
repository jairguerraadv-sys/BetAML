# BetAML — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores antes de subir a stack:
#   cp .env.example .env
#
# NUNCA comite o arquivo .env em repositórios de código.
# Para gerar novos segredos:
#   JWT_SECRET:          python -c "import secrets; print(secrets.token_hex(32))"
#   PII_ENCRYPTION_KEY:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=betaml
POSTGRES_PASSWORD=devpass
POSTGRES_DB=betaml_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=devpass

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

# ── Segredos da API (ALTERE EM STAGING/PRODUÇÃO) ─────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev-secret-change-me

# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PII_ENCRYPTION_KEY=ZGV2LXNlY3JldC1lbmNyeXB0aW9uLWtleS0zMmJ5

# ── Aplicação ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
ACCESS_TOKEN_EXPIRE_MIN=60
JWT_ALGORITHM=HS256

# CORS — em produção, lista separada por vírgulas:
# CORS_ALLOW_ORIGINS=https://app.betaml.io,https://admin.betaml.io
CORS_ALLOW_ORIGINS=http://localhost:3000

# Ingest DLQ — número máximo de retentativas antes de registrar o erro:
DLQ_MAX_RETRIES=3

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123

# ── URLs internas (normalmente não alterar em dev) ────────────────────────────
DATABASE_URL=postgresql://betaml:devpass@postgres:5432/betaml_dev
REDIS_URL=redis://:devpass@redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=redpanda:29092
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=betaml-lakehouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=betaml
ML_MODEL_BUCKET=betaml-models
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_TIMEOUT=30000
