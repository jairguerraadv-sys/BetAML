{
  "pythonVersion": "3.12",
  "typeCheckingMode": "basic",
  "extraPaths": ["services/api", "libs"],
  "reportMissingImports": "none",
  "reportMissingModuleSource": "none",
  "reportGeneralTypeIssues": "none",
  "reportAttributeAccessIssue": "none",
  "exclude": [
    "services/frontend",
    "**/node_modules",
    "**/__pycache__",
    "**/.git",
    "**/.venv",
    "**/venv",
    "**/.mypy_cache",
    "**/.pytest_cache"
  ]
}
