{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "BetAML SLI/SLO reliability dashboard",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Availability 5m (%)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "api:availability:ratio5m * 100",
          "legendFormat": "availability"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99.0 },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "API Error Rate 5m (%)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "api:error_rate:ratio5m * 100",
          "legendFormat": "error_rate"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.0 },
              { "color": "red", "value": 5.0 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "API p95 Latency 5m (ms)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "api:latency_p95_seconds5m * 1000",
          "legendFormat": "p95"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Ingest POST Throughput (req/s)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"betaml-api\",handler=~\"/ingest.*\",method=\"POST\"}[5m]))",
          "legendFormat": "ingest"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Availability and Error Budget",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "api:availability:ratio5m * 100",
          "legendFormat": "availability %"
        },
        {
          "expr": "99.5",
          "legendFormat": "SLO target 99.5%"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "API Latency p95 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "api:latency_p95_seconds5m * 1000",
          "legendFormat": "p95 ms"
        },
        {
          "expr": "500",
          "legendFormat": "SLO target 500ms"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Error Rate 5xx (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "api:error_rate:ratio5m * 100",
          "legendFormat": "5xx %"
        },
        {
          "expr": "1",
          "legendFormat": "SLO target 1%"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Ingest Endpoint Throughput (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"betaml-api\",handler=~\"/ingest.*\",method=\"POST\"}[1m]))",
          "legendFormat": "ingest req/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "tooltip": { "mode": "multi" } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["betaml", "slo", "sli", "reliability"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "BetAML - Reliability SLO",
  "uid": "betaml-reliability-slo",
  "version": 1
}
